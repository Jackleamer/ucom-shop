    "testimonials_qekHV6": {
      "type": "testimonials",
      "blocks": {
        "column_anNN6P": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Simple to Use, Perfect for Business",
            "text": "<p>“The IP phones we ordered from UCOM work seamlessly across our offices. They’re easy to set up, reliable, and make daily communication much smoother.”</p>",
            "author": "<em><strong>— Lawrence F</strong></em>"
          }
        },
        "column_T6EN6m": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Trusted Business Phone Solutions",
            "text": "<p>“If you’re looking for reliable and business-ready phone systems, UCOM is the provider to trust. Their products are dependable and perfect for any team setup.”</p>",
            "author": "<em><strong>— Krishnan P</strong></em>"
          }
        },
        "column_9XA3Uw": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Clear Calls, Easy to Use",
            "text": "<p>“Love our new IP phones from UCOM! They’re user-friendly, clear in call quality, and the accessories have made our workflow more efficient.”</p>",
            "author": "<em>— </em><em><strong>Chris K</strong></em>"
          }
        },
        "column_4XKrXn": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Keeping Our Team Connected",
            "text": "<p>“Great telecommunications partner for our business. UCOM’s IP phones are reliable, and their accessories keep our team connected every day.”</p>",
            "author": "<em><strong>— Sharon R</strong></em>"
          }
        },
        "column_AGenkw": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Great Support & Smooth Installation",
            "text": "<p>“Very satisfied with the IP phones and accessories we purchased. The team at UCOM made the whole process easy and supported us with setup right away.”</p>",
            "author": "<em><strong>— Eyal A</strong></em>"
          }
        },
        "column_rcCi3W": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Seamless Setup & Reliable Performance",
            "text": "<p>“We’ve been using UCOM phones for a few months now and the quality has been excellent. The interface is simple, and the accessories have made managing calls so much easier.”</p>",
            "author": "<em><strong>— Iqbal R</strong></em>"
          }
        }
      },
